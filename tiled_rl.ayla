import rl
import tiled
import json

type TiledMapRL struct {
    Map      tiled.TiledMap
    Textures map[string]rl.Texture2D
}

fun LoadMap(path string) (TiledMapRL, error) {
    m, err := tiled.LoadMap(path)

    ayla err != nil {
        back TiledMapRL{}, err
    }

    dir := ""
    four i, c := range path {
        ayla c == "/" || c == "\\" {
            dir = path[:i+1]
        }
    }

    textures := map[string]rl.Texture2D{}

    four _, ts := range m.Tilesets {
        ayla !json.Has(textures, ts.Image) {
            fullPath := dir + ts.Image
            textures[ts.Image] = rl.LoadTexture(fullPath)
        }
    }

    result := TiledMapRL{
        Map:      m,
        Textures: textures,
    }

    back result, nil
}

fun DrawMap(m TiledMapRL) {
    four _, layer := range m.Map.Layers {
        ayla !layer.Visible { next }

        four _, tile := range layer.Tiles {
            ayla tile.Id == 0 {
                next
            }

            ts := tiled.FindTileset(m.Map.Tilesets, tile.Id)
            ayla ts == nil {
                next
            }

            tex := m.Textures[ts.Image]

            src := rl.Rectangle{
                X: float(tile.SrcX),
                Y: float(tile.SrcY),
                Width:  float(ts.TileWidth),
                Height: float(ts.TileHeight),
            }

            pos := rl.Vector2{
                X: float(tile.X),
                Y: float(tile.Y),
            }

            rl.DrawTextureRec(tex, src, pos, rl.NewColor(255,255,255,255))
        }
    }
}

fun DrawMapEx(m TiledMapRL, tint rl.Color) {
    four _, layer := range m.Map.Layers {
        ayla !layer.Visible { next }

        four _, tile := range layer.Tiles {
            ayla tile.Id == 0 {
                next
            }

            ts := tiled.FindTileset(m.Map.Tilesets, tile.Id)
            ayla ts == nil {
                next
            }

            tex := m.Textures[ts.Image]

            src := rl.Rectangle{
                X: float(tile.SrcX),
                Y: float(tile.SrcY),
                Width:  float(ts.TileWidth),
                Height: float(ts.TileHeight),
            }

            pos := rl.Vector2{
                X: float(tile.X),
                Y: float(tile.Y),
            }

            rl.DrawTextureRec(tex, src, pos, tint)
        }
    }
}

fun DrawLayer(m TiledMapRL, layerName string) {
    four _, layer := range m.Map.Layers {
        ayla layer.Name != layerName { next }
        ayla !layer.Visible { next }

        four _, tile := range layer.Tiles {
            ayla tile.Id == 0 {
                next
            }

            ts := tiled.FindTileset(m.Map.Tilesets, tile.Id)
            ayla ts == nil {
                next
            }

            tex := m.Textures[ts.Image]

            src := rl.Rectangle{
                X: float(tile.SrcX),
                Y: float(tile.SrcY),
                Width:  float(ts.TileWidth),
                Height: float(ts.TileHeight),
            }

            pos := rl.Vector2{
                X: float(tile.X),
                Y: float(tile.Y),
            }

            rl.DrawTextureRec(tex, src, pos, rl.NewColor(255,255,255,255))
        }
    }
}

fun UnloadMap(m TiledMapRL) {
    four _, tex := range m.Textures {
        rl.UnloadTexture(tex)
    }
}
